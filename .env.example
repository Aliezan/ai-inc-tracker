NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://your-service.example.com

# Optional. If set, configure Pub/Sub push endpoint as:
# https://your-service.example.com/webhook/gmail?token=YOUR_WEBHOOK_SECRET
WEBHOOK_SECRET=

# Optional. If set, Telegram setWebhook uses this secret_token and requests are verified.
TELEGRAM_WEBHOOK_SECRET=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
GEMINI_CHAT_MODEL=gemini-2.5-flash

SHEET_ID=

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_PROJECT_ID=expense-income-gmail
PUBSUB_TOPIC=projects/expense-income-gmail/topics/gmail-watch
